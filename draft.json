{
  "draftId": "64d47e6f-620c-498e-abae-78b74462c12c",
  "title": "Elyra ΓÇö Editorial Luxury Rebuild",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Elyra ΓÇö Intelligent Workflow Platform</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js\"></script>\n  <style>\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap');\n\n    :root {\n      --color-bg: #f5f3ef;\n      --color-bg-warm: #faf8f4;\n      --color-text: #080808;\n      --color-text-soft: #333333;\n      --color-text-muted: #707070;\n      --color-accent: #c8b38e;\n      --font-serif: 'Playfair Display', serif;\n      --font-sans: 'Inter', sans-serif;\n    }\n\n    .font-serif { font-family: var(--font-serif); }\n    .font-sans { font-family: var(--font-sans); }\n\n    .editorial-grid {\n      display: grid;\n      grid-template-columns: repeat(12, 1fr);\n      gap: 2rem;\n    }\n\n    .line-tight { line-height: 0.95; }\n    .tracking-editorial { tracking: -0.04em; }\n\n    /* Transitions */\n    @view-transition {\n      navigation: auto;\n    }\n\n    ::view-transition-old(root),\n    ::view-transition-new(root) {\n      animation-duration: 0.4s;\n      animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n    }\n\n    @keyframes fade-out {\n      from { opacity: 1; transform: scale(1); }\n      to { opacity: 0; transform: scale(0.98); }\n    }\n\n    @keyframes fade-in {\n      from { opacity: 0; transform: scale(1.02); }\n      to { opacity: 1; transform: scale(1); }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"min-h-screen bg-[#f5f3ef] text-[#080808] selection:bg-[#c8b38e]/30\">\n    \n    <!-- Navigation -->\n    <nav class=\"fixed top-0 left-0 right-0 z-50 bg-[#f5f3ef] py-6 border-b border-[#e7e4df]/50\">\n      <div class=\"max-w-[1440px] mx-auto px-6 lg:px-16 flex items-center justify-between\">\n        <a href=\"/\" id=\"nav-logo-link\" class=\"font-serif text-2xl tracking-tighter\">Elyra</a>\n        <div class=\"hidden md:flex gap-12\">\n          <a href=\"#capability\" id=\"nav-link-product\" class=\"text-[11px] uppercase tracking-[0.2em] font-medium hover:text-[#c8b38e] transition-colors\">Product</a>\n          <a href=\"#workflow\" id=\"nav-link-process\" class=\"text-[11px] uppercase tracking-[0.2em] font-medium hover:text-[#c8b38e] transition-colors\">Process</a>\n          <a href=\"#testimonials\" id=\"nav-link-customers\" class=\"text-[11px] uppercase tracking-[0.2em] font-medium hover:text-[#c8b38e] transition-colors\">Customers</a>\n          <a href=\"#pricing\" id=\"nav-link-pricing\" class=\"text-[11px] uppercase tracking-[0.2em] font-medium hover:text-[#c8b38e] transition-colors\">Pricing</a>\n        </div>\n        <a href=\"#optin\" id=\"nav-cta-link\" class=\"text-[11px] uppercase tracking-[0.2em] font-semibold border-b border-black pb-1\">Begin Journey</a>\n      </div>\n    </nav>\n\n    <main class=\"relative\">\n      <!-- 1. HERO SECTION -->\n      <section class=\"pt-40 pb-24 px-6 lg:px-16 max-w-[1440px] mx-auto\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 items-start\">\n          <div class=\"lg:col-span-7\">\n            <p class=\"text-[11px] uppercase tracking-[0.3em] text-[#707070] mb-12\">Established 2026</p>\n            <h1 class=\"font-serif text-[clamp(4.5rem,10vw,10.5rem)] line-tight tracking-editorial mb-16\">\n              Focus by <br>\n              <span class=\"italic font-light\">design</span>\n            </h1>\n            <p class=\"text-xl font-light text-[#333333] max-w-lg leading-relaxed mb-12\">\n              Intentional work. Distilled to its essence. We remove the architectural noise of traditional management, leaving only clarity.\n            </p>\n            <div class=\"flex items-center gap-12\">\n              <a href=\"#optin\" id=\"hero-primary-cta\" class=\"bg-black text-white px-12 py-5 text-[12px] uppercase tracking-[0.2em] hover:bg-[#222] transition-transform active:scale-95\">Begin</a>\n              <div class=\"flex flex-col\">\n                <span class=\"text-[10px] uppercase tracking-[0.2em] text-[#707070]\">Trusted By</span>\n                <span class=\"text-[13px] font-medium\">Meridian, Solstice, & others</span>\n              </div>\n            </div>\n          </div>\n          <div class=\"lg:col-span-5 relative\">\n            <div class=\"aspect-[3/4] overflow-hidden\">\n              <img src=\"https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2069&auto=format&fit=crop\" alt=\"Minimal Architecture\" class=\"w-full h-full object-cover grayscale-[0.1] brightness-95\">\n            </div>\n            <!-- Overlapping beige block -->\n            <div class=\"absolute -bottom-10 -left-12 bg-[#c8b38e] p-10 hidden xl:block\">\n              <span class=\"text-[10px] uppercase tracking-[0.4em] text-white/80 block mb-4\">Collection 01</span>\n              <h2 class=\"font-serif text-3xl text-white font-light\">The New Standard <br>in Clarity.</h2>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <!-- 2. QUIET FOCUS -->\n      <section class=\"py-32 bg-[#faf8f4] border-y border-[#e7e4df]\">\n        <div class=\"max-w-[1440px] mx-auto px-6 lg:px-16\">\n          <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-24 items-center\">\n            <div class=\"relative\">\n              <div class=\"aspect-[16/10] overflow-hidden\">\n                <img src=\"https://images.unsplash.com/photo-1600607688969-a5e2f7b82f05?q=80&w=2100&auto=format&fit=crop\" alt=\"Minimalist Space\" class=\"w-full h-full object-cover\">\n              </div>\n              <div class=\"absolute -top-12 -right-12 w-64 aspect-square overflow-hidden shadow-2xl hidden lg:block\">\n                <img src=\"https://images.unsplash.com/photo-1517502884422-41eaead166d4?q=80&w=1925&auto=format&fit=crop\" alt=\"Detail\" class=\"w-full h-full object-cover grayscale\">\n              </div>\n            </div>\n            <div class=\"max-w-xl\">\n              <p class=\"text-[11px] uppercase tracking-[0.3em] text-[#c8b38e] mb-6 font-semibold\">Philosophy</p>\n              <h2 class=\"font-serif text-6xl mb-8 tracking-tighter\">Quiet focus.</h2>\n              <p class=\"text-lg font-light text-[#333333] leading-[1.8] mb-12\">\n                The best systems disappear. We removed the noise, leaving only the framework you need to do your core work. Our approach prioritizes deep work sessions over frantic task management.\n              </p>\n              <div class=\"flex items-center gap-6\">\n                <span class=\"font-serif text-6xl font-light text-[#c8b38e]\">40%</span>\n                <span class=\"text-[11px] uppercase tracking-[0.2em] text-[#707070] border-l border-[#e7e4df] pl-6 py-2\">Increase in <br>Focus duration</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <!-- 3. BUILT FOR DEPTH -->\n      <section id=\"capability\" class=\"py-32 px-6 lg:px-16 max-w-[1440px] mx-auto\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16\">\n          <div class=\"lg:col-span-4 sticky top-32 h-fit\">\n            <p class=\"text-[11px] uppercase tracking-[0.3em] text-[#707070] mb-6\">Capabilities</p>\n            <h2 class=\"font-serif text-5xl mb-8 leading-tight\">Built for <br>depth</h2>\n            <p class=\"text-base font-light text-[#707070]\">Every pixel is intentional, every interaction is earned. No generic templates, no unnecessary bells.</p>\n          </div>\n          <div class=\"lg:col-span-8 space-y-24\">\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\">\n              <div class=\"pt-12 border-t border-[#e7e4df]\">\n                <span class=\"font-serif text-2xl text-[#c8b38e] italic mb-6 block\">01.</span>\n                <h3 class=\"font-serif text-3xl mb-4\">Focus</h3>\n                <p class=\"text-sm font-light text-[#333333] leading-relaxed\">Surface what matters. Elyra organizes tasks quietly, maintaining momentum without the need for active management.</p>\n              </div>\n              <div class=\"pt-12 border-t border-[#e7e4df] md:mt-16\">\n                <span class=\"font-serif text-2xl text-[#c8b38e] italic mb-6 block\">02.</span>\n                <h3 class=\"font-serif text-3xl mb-4\">Collaboration</h3>\n                <p class=\"text-sm font-light text-[#333333] leading-relaxed\">Work together without the noise. Threaded discussions and shared context keep your team aligned.</p>\n              </div>\n              <div class=\"pt-12 border-t border-[#e7e4df]\">\n                <span class=\"font-serif text-2xl text-[#c8b38e] italic mb-6 block\">03.</span>\n                <h3 class=\"font-serif text-3xl mb-4\">Automation</h3>\n                <p class=\"text-sm font-light text-[#333333] leading-relaxed\">Automate routine actions naturally. Flexible rules run quietly in the background without rigid constraints.</p>\n              </div>\n              <div class=\"pt-12 border-t border-[#e7e4df] md:mt-16\">\n                <span class=\"font-serif text-2xl text-[#c8b38e] italic mb-6 block\">04.</span>\n                <h3 class=\"font-serif text-3xl mb-4\">Workspace</h3>\n                <p class=\"text-sm font-light text-[#333333] leading-relaxed\">One space for everything. Documents, discussions, tasks, and timelines exist in a clear environment.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <!-- 4. INTENTIONAL PROCESS -->\n      <section id=\"workflow\" class=\"py-32 bg-white\">\n        <div class=\"max-w-[1440px] mx-auto px-6 lg:px-16\">\n          <div class=\"text-center mb-24\">\n            <p class=\"text-[11px] uppercase tracking-[0.3em] text-[#707070] mb-6\">Process</p>\n            <h2 class=\"font-serif text-7xl tracking-tighter mb-8\">Intentional process</h2>\n          </div>\n          <div class=\"grid grid-cols-1 md:grid-cols-3 gap-16\">\n            <div class=\"group\">\n              <div class=\"aspect-[4/5] overflow-hidden mb-8\">\n                <img src=\"https://images.unsplash.com/photo-1542744094-24638eff58bb?q=80&w=2071&auto=format&fit=crop\" alt=\"Step 01\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 grayscale\">\n              </div>\n              <span class=\"text-[11px] uppercase tracking-[0.4em] text-[#c8b38e] block mb-4 font-bold italic\">Phase I</span>\n              <h3 class=\"font-serif text-3xl mb-4\">Gather</h3>\n              <p class=\"text-sm font-light text-[#333333] leading-relaxed\">Bring your projects and team into one workspace without forcing a new methodology.</p>\n            </div>\n            <div class=\"group md:mt-24\">\n              <div class=\"aspect-[4/5] overflow-hidden mb-8\">\n                <img src=\"https://images.unsplash.com/photo-1497366754035-f200968a6e72?q=80&w=2069&auto=format&fit=crop\" alt=\"Step 02\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 grayscale\">\n              </div>\n              <span class=\"text-[11px] uppercase tracking-[0.4em] text-[#c8b38e] block mb-4 font-bold italic\">Phase II</span>\n              <h3 class=\"font-serif text-3xl mb-4\">Organize</h3>\n              <p class=\"text-sm font-light text-[#333333] leading-relaxed\">Systematically surface what needs attention. Structure emerges naturally.</p>\n            </div>\n            <div class=\"group md:mt-12\">\n              <div class=\"aspect-[4/5] overflow-hidden mb-8\">\n                <img src=\"https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=2070&auto=format&fit=crop\" alt=\"Step 03\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 grayscale\">\n              </div>\n              <span class=\"text-[11px] uppercase tracking-[0.4em] text-[#c8b38e] block mb-4 font-bold italic\">Phase III</span>\n              <h3 class=\"font-serif text-3xl mb-4\">Focus</h3>\n              <p class=\"text-sm font-light text-[#333333] leading-relaxed\">With distractions removed, return to uninterrupted work and steady progress.</p>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <!-- 5. TESTIMONIALS -->\n      <section id=\"testimonials\" class=\"py-32 px-6 lg:px-16 max-w-[1440px] mx-auto\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-24\">\n          <div>\n             <p class=\"text-[11px] uppercase tracking-[0.3em] text-[#707070] mb-6\">Perspective</p>\n             <h2 class=\"font-serif text-5xl mb-12\">Voices of <br>intent</h2>\n          </div>\n          <div class=\"space-y-32\">\n            <blockquote class=\"relative\">\n              <iconify-icon icon=\"lucide:quote\" class=\"text-6xl text-[#c8b38e]/20 absolute -top-8 -left-8\"></iconify-icon>\n              <p class=\"font-serif text-3xl font-light italic leading-relaxed mb-8\">\n                \"Elyra fundamentally changed how our engineering team approaches context. It brings a necessary sense of architectural clarity to our daily operations.\"\n              </p>\n              <footer class=\"flex flex-col gap-2 border-l-2 border-[#c8b38e] pl-6\">\n                <span class=\"font-semibold text-sm\">Sarah Chen</span>\n                <span class=\"text-[12px] uppercase tracking-widest text-[#707070]\">VP Product, Meridian</span>\n              </footer>\n            </blockquote>\n            <blockquote class=\"relative\">\n              <iconify-icon icon=\"lucide:quote\" class=\"text-6xl text-[#c8b38e]/20 absolute -top-8 -left-8\"></iconify-icon>\n              <p class=\"font-serif text-3xl font-light italic leading-relaxed mb-8\">\n                \"In an era of hyper-connected noise, Elyra is the first platform that actually helped our studio slow down and do better work.\"\n              </p>\n              <footer class=\"flex flex-col gap-2 border-l-2 border-[#c8b38e] pl-6\">\n                <span class=\"font-semibold text-sm\">Amara Osei</span>\n                <span class=\"text-[12px] uppercase tracking-widest text-[#707070]\">CDO, Solstice Studio</span>\n              </footer>\n            </blockquote>\n          </div>\n        </div>\n      </section>\n\n      <!-- 6. PRICING -->\n      <section id=\"pricing\" class=\"py-32 bg-[#faf8f4]\">\n        <div class=\"max-w-[1440px] mx-auto px-6 lg:px-16\">\n          <div class=\"text-center mb-24\">\n            <p class=\"text-[11px] uppercase tracking-[0.3em] text-[#707070] mb-6\">Pricing</p>\n            <h2 class=\"font-serif text-6xl tracking-tighter\">Transparent tiers</h2>\n          </div>\n          <div class=\"grid grid-cols-1 md:grid-cols-3 gap-0 border border-[#e7e4df]\">\n            <!-- Starter -->\n            <div class=\"p-16 flex flex-col items-center text-center\">\n              <span class=\"text-[10px] uppercase tracking-[0.2em] mb-12\">Starter</span>\n              <div class=\"font-serif text-5xl mb-8 font-light\">$0</div>\n              <p class=\"text-xs font-light text-[#707070] mb-12 uppercase tracking-widest\">For individuals</p>\n              <ul class=\"space-y-4 mb-16 text-sm font-light\">\n                <li>3 Projects</li>\n                <li>Core Modules</li>\n                <li>Public Boards</li>\n              </ul>\n              <a href=\"#\" id=\"pricing-starter-cta\" class=\"w-full border border-black py-4 text-[11px] uppercase tracking-[0.2em] font-semibold hover:bg-black hover:text-white transition-colors\">Start Free</a>\n            </div>\n            <!-- Professional (DARK CARD) -->\n            <div class=\"p-16 bg-[#080808] text-white flex flex-col items-center text-center\">\n              <span class=\"text-[10px] uppercase tracking-[0.2em] mb-12 text-[#c8b38e]\">Professional</span>\n              <div class=\"font-serif text-5xl mb-8 font-light\">$24</div>\n              <p class=\"text-xs font-light text-white/60 mb-12 uppercase tracking-widest\">For modern teams</p>\n              <ul class=\"space-y-4 mb-16 text-sm font-light\">\n                <li>Unlimited Projects</li>\n                <li>Automation Engine</li>\n                <li>Private Spaces</li>\n                <li>Priority Support</li>\n              </ul>\n              <a href=\"#\" id=\"pricing-pro-cta\" class=\"w-full bg-[#c8b38e] text-white py-4 text-[11px] uppercase tracking-[0.2em] font-semibold hover:bg-[#b5a07c] transition-colors\">Select Tier</a>\n            </div>\n            <!-- Enterprise -->\n            <div class=\"p-16 flex flex-col items-center text-center\">\n              <span class=\"text-[10px] uppercase tracking-[0.2em] mb-12\">Enterprise</span>\n              <div class=\"font-serif text-5xl mb-8 font-light\">Custom</div>\n              <p class=\"text-xs font-light text-[#707070] mb-12 uppercase tracking-widest\">Large Scale</p>\n              <ul class=\"space-y-4 mb-16 text-sm font-light\">\n                <li>SSO & Security</li>\n                <li>Custom Reporting</li>\n                <li>Dedicated Success</li>\n              </ul>\n              <a href=\"#\" id=\"pricing-enterprise-cta\" class=\"w-full border border-black py-4 text-[11px] uppercase tracking-[0.2em] font-semibold hover:bg-black hover:text-white transition-colors\">Talk To Us</a>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <!-- 7. FINAL CTA -->\n      <section class=\"py-48 px-6 lg:px-16 text-center\">\n        <div class=\"max-w-4xl mx-auto\">\n          <h2 class=\"font-serif text-[clamp(4rem,10vw,10rem)] line-tight tracking-editorial mb-16\">Begin <br> <span class=\"italic font-light\">today.</span></h2>\n          <p class=\"text-xl font-light text-[#333333] mb-16\">The system that grows with your intention.</p>\n          <div class=\"flex flex-col sm:flex-row items-center justify-center gap-8\">\n            <a href=\"#\" id=\"final-primary-cta\" class=\"bg-black text-white px-16 py-6 text-[12px] uppercase tracking-[0.2em] hover:bg-[#222] transition-colors\">Launch Elyra</a>\n            <span class=\"text-[11px] uppercase tracking-[0.3em] text-[#707070]\">No credit card required</span>\n          </div>\n        </div>\n      </section>\n\n    </main>\n\n    <footer class=\"py-24 px-6 lg:px-16 border-t border-[#e7e4df] bg-white\">\n      <div class=\"max-w-[1440px] mx-auto\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 mb-24\">\n          <div class=\"lg:col-span-5\">\n            <a href=\"/\" id=\"footer-logo-link\" class=\"font-serif text-3xl mb-8 block\">Elyra</a>\n            <p class=\"text-base font-light text-[#707070] max-w-sm mb-12\">Refined workflow for teams who value clarity above noise.</p>\n            <div class=\"flex gap-8\">\n               <a href=\"#\" id=\"f-tw\" class=\"text-xl hover:text-[#c8b38e] transition-colors\"><iconify-icon icon=\"lucide:twitter\"></iconify-icon></a>\n               <a href=\"#\" id=\"f-ln\" class=\"text-xl hover:text-[#c8b38e] transition-colors\"><iconify-icon icon=\"lucide:linkedin\"></iconify-icon></a>\n               <a href=\"#\" id=\"f-gh\" class=\"text-xl hover:text-[#c8b38e] transition-colors\"><iconify-icon icon=\"lucide:github\"></iconify-icon></a>\n            </div>\n          </div>\n          <div class=\"lg:col-span-2\">\n            <h4 class=\"text-[11px] uppercase tracking-[0.3em] text-[#707070] mb-8\">Product</h4>\n            <ul class=\"space-y-4 text-sm font-light\">\n              <li><a href=\"#\" id=\"f-l-01\" class=\"hover:text-[#c8b38e]\">Overview</a></li>\n              <li><a href=\"#\" id=\"f-l-02\" class=\"hover:text-[#c8b38e]\">Capabilities</a></li>\n              <li><a href=\"#\" id=\"f-l-03\" class=\"hover:text-[#c8b38e]\">Workflow</a></li>\n            </ul>\n          </div>\n          <div class=\"lg:col-span-2\">\n            <h4 class=\"text-[11px] uppercase tracking-[0.3em] text-[#707070] mb-8\">Company</h4>\n            <ul class=\"space-y-4 text-sm font-light\">\n              <li><a href=\"#\" id=\"f-l-04\" class=\"hover:text-[#c8b38e]\">About</a></li>\n              <li><a href=\"#\" id=\"f-l-05\" class=\"hover:text-[#c8b38e]\">Careers</a></li>\n              <li><a href=\"#\" id=\"f-l-06\" class=\"hover:text-[#c8b38e]\">Journal</a></li>\n            </ul>\n          </div>\n          <div class=\"lg:col-span-3\">\n            <h4 class=\"text-[11px] uppercase tracking-[0.3em] text-[#707070] mb-8\">Newsletter</h4>\n            <form id=\"footer-subscribe\" class=\"flex border-b border-black pb-2\">\n              <input type=\"email\" placeholder=\"Email address\" class=\"bg-transparent w-full text-sm font-light outline-none\">\n              <button type=\"submit\" id=\"footer-sub-btn\" class=\"text-sm uppercase tracking-widest font-bold\"><iconify-icon icon=\"lucide:arrow-right\"></iconify-icon></button>\n            </form>\n          </div>\n        </div>\n        <div class=\"flex flex-col md:flex-row justify-between items-center pt-12 border-t border-[#f0eee9] text-[11px] uppercase tracking-[0.2em] text-[#9e9e9e]\">\n          <p>┬⌐ 2026 Elyra Studio</p>\n          <div class=\"flex gap-12 mt-6 md:mt-0\">\n            <a href=\"#\" id=\"f-l-07\" class=\"hover:text-black\">Privacy</a>\n            <a href=\"#\" id=\"f-l-08\" class=\"hover:text-black\">Terms</a>\n            <a href=\"#\" id=\"f-l-09\" class=\"hover:text-black\">Security</a>\n          </div>\n        </div>\n      </div>\n    </footer>\n  </div>\n</body>\n</html>"
}
